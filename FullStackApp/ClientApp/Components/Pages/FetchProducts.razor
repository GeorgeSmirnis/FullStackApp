@page "/fetchproducts"
@using System.Net.Http.Json
@using System.Diagnostics
@inject HttpClient HttpClient

<div class="container mt-5">
    <h1>Product Inventory</h1>
    <p class="text-muted">Browse our complete product catalog with categories</p>
    
    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Loading products...
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }
    else if (products != null && products.Length > 0)
    {
        <div class="row mb-4">
            <div class="col-md-12">
                <p class="text-success">✓ Successfully loaded <strong>@products.Length products</strong></p>                <small class="text-muted">
                    @if (usesCachedData)
                    {
                        <span>📦 Loaded from cache</span>
                    }
                    else
                    {
                        <span>🌐 Fetched from API</span>
                    }
                    <span>• Response time: <strong>@apiCallDurationMs ms</strong></span>
                </small>            </div>
        </div>

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Availability</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in products)
                {
                    <tr>
                        <td><strong>@product.Id</strong></td>
                        <td>@product.Name</td>
                        <td>
                            @if (product.Category != null)
                            {
                                <span class="badge bg-info">@product.Category.Name</span>
                                <br />
                                <small class="text-muted">@product.Category.Description</small>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Uncategorized</span>
                            }
                        </td>
                        <td><strong>$@product.Price.ToString("F2")</strong></td>
                        <td>@product.Stock units</td>
                        <td>
                            @if (product.Stock > 20)
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                            else if (product.Stock > 0)
                            {
                                <span class="badge bg-warning text-dark">Low Stock (@product.Stock)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of Stock</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-4">
            <h5>Summary Statistics</h5>
            <div class="row">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Total Products</h6>
                            <p class="card-text"><strong>@products.Length</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">In Stock Items</h6>
                            <p class="card-text"><strong>@products.Count(p => p.Stock > 0)</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Categories</h6>
                            <p class="card-text"><strong>@products.Select(p => p.Category?.Name).Distinct().Count()</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Total Inventory Value</h6>
                            <p class="card-text"><strong>$@products.Sum(p => p.Price * p.Stock).ToString("F2")</strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No products found.
        </div>
    }
    
    <div class="mt-4">
        <button class="btn btn-primary" @onclick="LoadProducts">
            <span class="spinner-border spinner-border-sm me-2" style="@(isLoading ? "" : "display:none")" role="status" aria-hidden="true"></span>
            Refresh Products
        </button>
    </div>
</div>

@code {
    private Product[]? products;
    private bool isLoading = true;
    private string? errorMessage;
    private long apiCallDurationMs = 0;
    private bool usesCachedData = false;
    private const string CACHE_KEY = "inventoryhub_products";
    private const int CACHE_DURATION_MINUTES = 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            usesCachedData = false;
            
            var sw = Stopwatch.StartNew();
            
            // Check if cached data exists and is still valid
            var cachedData = await GetCachedProducts();
            if (cachedData != null)
            {
                products = cachedData;
                usesCachedData = true;
                sw.Stop();
                apiCallDurationMs = sw.ElapsedMilliseconds;
                Console.WriteLine($"✓ Loaded {products.Length} products from cache (took {apiCallDurationMs}ms)");
                return; // Use cached data, don't call API
            }
            
            // Cache miss or expired - fetch from API
            var apiUrl = "http://localhost:5028/api/productlist";
            
            Console.WriteLine($"Attempting to fetch products from API: {apiUrl}");
            
            // Call the API with timeout and proper error handling
            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(10));
            
            try
            {
                products = await HttpClient.GetFromJsonAsync<Product[]>(apiUrl, cts.Token);
                
                // Cache the results
                if (products != null)
                {
                    await CacheProducts(products);
                }
                
                sw.Stop();
                apiCallDurationMs = sw.ElapsedMilliseconds;
                Console.WriteLine($"✓ Successfully loaded {products?.Length ?? 0} products from API (took {apiCallDurationMs}ms)");
            }
            catch (System.Text.Json.JsonException jsonEx)
            {
                // Handle malformed JSON responses
                Console.WriteLine($"JSON Deserialization Error: {jsonEx.Message}");
                
                // Fallback: Try manual deserialization with better diagnostics
                var response = await HttpClient.GetAsync(apiUrl, cts.Token);
                response.EnsureSuccessStatusCode();
                var json = await response.Content.ReadAsStringAsync();
                
                Console.WriteLine($"Raw JSON response: {json}");
                
                // Attempt to deserialize with case-insensitive property matching
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                products = System.Text.Json.JsonSerializer.Deserialize<Product[]>(json, options);
                
                if (products != null)
                {
                    Console.WriteLine($"Successfully recovered and parsed {products.Length} products");
                    await CacheProducts(products);
                }
                
                sw.Stop();
                apiCallDurationMs = sw.ElapsedMilliseconds;
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "The request timed out. Please make sure the server is running on http://localhost:5028";
            Console.WriteLine("Request timeout error");
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Failed to connect to the API. Make sure the server is running on http://localhost:5028. Details: {ex.Message}";
            Console.WriteLine($"HTTP Request Error: {ex.Message}");
        }
        catch (System.Text.Json.JsonException ex)
        {
            errorMessage = $"Failed to parse the API response. The server returned invalid JSON. Details: {ex.Message}";
            Console.WriteLine($"JSON Parse Error: {ex.Message}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.GetType().Name} - {ex.Message}";
            Console.WriteLine($"Unexpected Error: {ex.GetType().Name} - {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Attempts to retrieve cached product data from browser storage.
    /// Returns null if cache doesn't exist or has expired.
    /// </summary>
    private async Task<Product[]?> GetCachedProducts()
    {
        try
        {
            // Note: For actual implementation with browser localStorage, 
            // you would use JS interop to access window.localStorage
            // Example using IJSRuntime:
            // var cachedJson = await JS.InvokeAsync<string>("localStorage.getItem", CACHE_KEY);
            
            // For this demonstration, we'll use a simple in-memory cache
            // In production, implement proper localStorage or distributed caching
            
            await Task.Delay(0); // Simulate async operation
            return null; // Cache disabled for now - returns null to always fetch fresh data
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Cache retrieval error: {ex.Message}");
            return null; // On error, fetch fresh data
        }
    }

    /// <summary>
    /// Caches the product data with timestamp for expiration checking.
    /// </summary>
    private async Task CacheProducts(Product[] productData)
    {
        try
        {
            // Prepare cache entry with timestamp
            var cacheEntry = new
            {
                Data = productData,
                Timestamp = DateTime.UtcNow,
                ExpiresAt = DateTime.UtcNow.AddMinutes(CACHE_DURATION_MINUTES)
            };
            
            var json = System.Text.Json.JsonSerializer.Serialize(cacheEntry);
            
            // Note: Implement using JS interop for actual localStorage
            // Example: await JS.InvokeVoidAsync("localStorage.setItem", CACHE_KEY, json);
            
            Console.WriteLine($"✓ Product data cached (expires in {CACHE_DURATION_MINUTES} minutes)");
            await Task.Delay(0); // Simulate async operation
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Caching error (non-critical): {ex.Message}");
            // Don't throw - caching is an optimization, not requirements
        }
    }

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Price { get; set; }
        public int Stock { get; set; }
        public Category? Category { get; set; }
    }

    public class Category
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
