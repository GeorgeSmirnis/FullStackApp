@page "/"

<PageTitle>Home - EventEase</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <h1>Welcome to EventEase</h1>
        <p class="tagline">Discover and join amazing corporate and social events</p>
        
        <div class="cta-buttons">
            <a href="/events" class="btn btn-primary-large">Browse Events</a>
            <a href="/events" class="btn btn-secondary-large">Learn More</a>
        </div>
    </div>

    <div class="features-section">
        <h2>Why Choose EventEase?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">📅</div>
                <h3>Easy Discovery</h3>
                <p>Browse and discover events that match your interests and schedule.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">👥</div>
                <h3>Connect & Network</h3>
                <p>Meet professionals and build meaningful connections at our events.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎯</div>
                <h3>Quick Registration</h3>
                <p>Register for events in just a few clicks and get instant confirmation.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .home-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .hero-section {
        text-align: center;
        padding: 60px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
        margin-bottom: 60px;
    }

    .hero-section h1 {
        font-size: 3rem;
        margin: 0 0 10px 0;
        font-weight: 700;
    }

    .tagline {
        font-size: 1.3rem;
        margin: 0 0 30px 0;
        opacity: 0.95;
    }

    .cta-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary-large,
    .btn-secondary-large {
        padding: 15px 40px;
        font-size: 1.1rem;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        cursor: pointer;
        font-weight: 600;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: inline-block;
    }

    .btn-primary-large {
        background-color: white;
        color: #667eea;
    }

    .btn-primary-large:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    }

    .btn-secondary-large {
        background-color: transparent;
        color: white;
        border: 2px solid white;
    }

    .btn-secondary-large:hover {
        background-color: rgba(255, 255, 255, 0.1);
