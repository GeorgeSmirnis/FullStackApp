@page "/events"
@using EventEase.Models
@using EventEase.Services
@using EventEase.Components.Shared
@inject IEventService EventService
@rendermode InteractiveServer

<PageTitle>Events - EventEase</PageTitle>

<div class="events-container">
    <div class="events-header">
        <h1>Upcoming Events</h1>
        <p class="subtitle">Browse and register for exciting corporate and social events</p>
        
        <div class="search-filter">
            <input type="text" placeholder="Search events..." @bind="SearchQuery" @bind:event="oninput" @onchange="OnSearchChanged" />
            <span class="total-events">Total: @FilteredEvents.Count events</span>
        </div>
    </div>

    @if (LoadingState == LoadState.Loading)
    {
        <div class="loading-spinner">
            <p>Loading events...</p>
        </div>
    }
    else if (LoadingState == LoadState.Error)
    {
        <div class="error-container">
            <h2>Error Loading Events</h2>
            <p>@ErrorMessage</p>
            <button @onclick="ReloadEvents" class="btn btn-primary">Try Again</button>
        </div>
    }
    else if (FilteredEvents.Count == 0)
    {
        <div class="no-events">
            <p>@(string.IsNullOrEmpty(SearchQuery) ? "No events available." : $"No events match '{SearchQuery}'.")</p>
        </div>
    }
    else
    {
        <div class="events-grid">
            @foreach (var evt in PaginatedEvents)
            {
                <EventCard EventData="evt" />
            }
        </div>

        @if (TotalPages > 1)
        {
            <div class="pagination">
                <button @onclick="PreviousPage" disabled="@(CurrentPage == 1)" class="btn-pagination">← Previous</button>
                
                <div class="page-numbers">
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNum = i;
                        <button @onclick="@(() => GoToPage(pageNum))" 
                                class="@($"page-number {(CurrentPage == pageNum ? "active" : "")}")">
                            @pageNum
                        </button>
                    }
                </div>

                <button @onclick="NextPage" disabled="@(CurrentPage == TotalPages)" class="btn-pagination">Next →</button>
            </div>

            <div class="pagination-info">
                <p>Page @CurrentPage of @TotalPages (@ItemsPerPage events per page)</p>
            </div>
        }
    }
</div>

<style>
    .events-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    h1 {
        color: #333;
        margin-bottom: 10px;
        font-size: 2.5rem;
    }

    .subtitle {
        color: #666;
        font-size: 1.1rem;
        margin-bottom: 20px;
    }

    .search-filter {
        display: flex;
        gap: 15px;
        align-items: center;
        margin-bottom: 20px;
    }

    .search-filter input {
        flex: 1;
        max-width: 300px;
        padding: 10px 15px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 0.95rem;
    }

    .search-filter input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .total-events {
        color: #666;
        font-size: 0.95rem;
    }

    .loading-spinner {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }

    .error-container {
        background: #ffe6e6;
        border: 1px solid #c53030;
        border-radius: 8px;
        padding: 40px;
        text-align: center;
        color: #742a2a;
    }

    .error-container h2 {
        color: #c53030;
        margin: 0 0 15px 0;
    }

    .error-container p {
        margin: 0 0 20px 0;
    }

    .error-container .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.95rem;
        transition: background-color 0.3s ease;
    }

    .error-container .btn-primary {
        background-color: #667eea;
        color: white;
    }

    .error-container .btn-primary:hover {
        background-color: #5568d3;
    }

    .no-events {
        text-align: center;
        padding: 60px 20px;
        color: #999;
        font-size: 1.1rem;
    }

    .events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .page-numbers {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .btn-pagination,
    .page-number {
        padding: 8px 12px;
        border: 1px solid #ddd;
        background-color: white;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .btn-pagination:hover:not(:disabled),
    .page-number:hover:not(.active) {
        background-color: #f5f5f5;
        border-color: #667eea;
    }

    .btn-pagination:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-number.active {
        background-color: #667eea;
        color: white;
        border-color: #667eea;
    }

    .pagination-info {
        text-align: center;
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 20px;
    }

    @("@media (max-width: 768px)") {
        .events-grid {
            grid-template-columns: 1fr;
        }

        h1 {
            font-size: 2rem;
        }

        .search-filter {
            flex-direction: column;
        }

        .search-filter input {
            max-width: 100%;
        }

        .pagination {
            flex-wrap: wrap;
        }

        .page-numbers {
            flex-wrap: wrap;
            order: 3;
            width: 100%;
        }
    }

</style>

@code {
    private List<Event> AllEvents = new();
    private List<Event> FilteredEvents = new();
    private List<Event> PaginatedEvents = new();
    private string SearchQuery = string.Empty;
    private int CurrentPage = 1;
    private int ItemsPerPage = 6;
    private LoadState LoadingState = LoadState.Loading;
    private string ErrorMessage = string.Empty;

    private enum LoadState
    {
        Loading,
        Success,
        Error
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredEvents.Count / ItemsPerPage));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            AllEvents = await EventService.GetAllEventsAsync();
            FilteredEvents = new List<Event>(AllEvents);
            UpdatePaginatedEvents();
            LoadingState = LoadState.Success;
        }
        catch (Exception ex)
        {
            LoadingState = LoadState.Error;
            ErrorMessage = $"Failed to load events: {ex.Message}";
        }
    }

    private void UpdatePaginatedEvents()
    {
        int startIndex = (CurrentPage - 1) * ItemsPerPage;
        PaginatedEvents = FilteredEvents
            .Skip(startIndex)
            .Take(ItemsPerPage)
            .ToList();
    }

    private void OnSearchChanged()
    {
        CurrentPage = 1;
        
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            FilteredEvents = new List<Event>(AllEvents);
        }
        else
        {
            var query = SearchQuery.ToLower();
            FilteredEvents = AllEvents
                .Where(e => 
                    (e.Name?.ToLower().Contains(query) ?? false) ||
                    (e.Location?.ToLower().Contains(query) ?? false) ||
                    (e.Description?.ToLower().Contains(query) ?? false)
                )
                .ToList();
        }

        UpdatePaginatedEvents();
    }

    private void GoToPage(int pageNum)
    {
        if (pageNum >= 1 && pageNum <= TotalPages)
        {
            CurrentPage = pageNum;
            UpdatePaginatedEvents();
        }
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
            UpdatePaginatedEvents();
        }
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            UpdatePaginatedEvents();
        }
    }

    private async Task ReloadEvents()
    {
        LoadingState = LoadState.Loading;
        try
        {
            AllEvents = await EventService.GetAllEventsAsync();
            FilteredEvents = new List<Event>(AllEvents);
            CurrentPage = 1;
            UpdatePaginatedEvents();
            LoadingState = LoadState.Success;
        }
        catch (Exception ex)
        {
            LoadingState = LoadState.Error;
            ErrorMessage = $"Failed to reload events: {ex.Message}";
        }
    }
}
