@using EventEase.Models
@rendermode InteractiveServer

@if (IsValid)
{
    <div class="event-card">
        <div class="card-header">
            @if (!string.IsNullOrEmpty(EventData?.ImageUrl))
            {
                <img src="@EventData.ImageUrl" alt="@(EventData?.Name ?? "Event")" class="event-image" />
            }
            else
            {
                <div class="event-image-placeholder">No Image</div>
            }
        </div>
        <div class="card-body">
            <h3 class="event-title">@(EventData?.Name ?? "Untitled Event")</h3>
            
            <div class="event-info">
                <p class="event-detail">
                    <strong>📅 Date:</strong> @GetFormattedDate()
                </p>
                <p class="event-detail">
                    <strong>📍 Location:</strong> @(EventData?.Location ?? "Location TBD")
                </p>
                @if (!string.IsNullOrEmpty(EventData?.Description))
                {
                    <p class="event-detail">
                        <strong>Description:</strong> @(TruncateDescription(EventData.Description, 100))
                    </p>
                }
                <p class="event-detail">
                    <strong>Attendees:</strong> @GetAttendeeCount()
                </p>
            </div>

            <div class="card-footer">
                <a href="@GetDetailsLink()" class="btn btn-primary">View Details</a>
                <a href="@GetRegisterLink()" class="btn btn-success" aria-disabled="@IsEventFull()">@GetRegisterButtonText()</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="event-card error-card">
        <div class="card-body">
            <p class="error-message">Unable to display event. Invalid or missing data.</p>
        </div>
    </div>
}

@code {
    [Parameter]
    public Event? EventData { get; set; }

    private bool IsValid { get; set; }

    protected override void OnParametersSet()
    {
        // Validate event data
        IsValid = ValidateEventData();
    }

    private bool ValidateEventData()
    {
        if (EventData == null)
            return false;

        // Check required fields
        if (string.IsNullOrWhiteSpace(EventData.Name))
            return false;

        if (EventData.Id <= 0)
            return false;

        // Validate numeric fields
        if (EventData.MaxAttendees <= 0)
            return false;

        if (EventData.RegisteredAttendees < 0 || EventData.RegisteredAttendees > EventData.MaxAttendees)
            return false;

        // Ensure date is reasonable (not in the past by more than a year or more than 10 years in future)
        var today = DateTime.Now;
        if (EventData.Date < today.AddYears(-1) || EventData.Date > today.AddYears(10))
            return false;

        return true;
    }

    private string GetFormattedDate()
    {
        try
        {
            if (EventData?.Date == default)
                return "Date TBD";
            
            return EventData?.Date.ToString("MMMM dd, yyyy") ?? "Date TBD";
        }
        catch
        {
            return "Invalid Date";
        }
    }

    private string TruncateDescription(string? description, int maxLength)
    {
        if (string.IsNullOrEmpty(description))
            return string.Empty;

        if (description.Length <= maxLength)
            return description;

        return description.Substring(0, maxLength) + "...";
    }

    private string GetAttendeeCount()
    {
        if (EventData == null)
            return "0 / 0";

        return $"{Math.Max(0, EventData.RegisteredAttendees)} / {Math.Max(0, EventData.MaxAttendees)}";
    }

    private string GetDetailsLink()
    {
        return EventData?.Id > 0 ? $"event-details/{EventData.Id}" : "#";
    }

    private string GetRegisterLink()
    {
        return EventData?.Id > 0 ? $"register/{EventData.Id}" : "#";
    }

    private bool IsEventFull()
    {
        if (EventData == null)
            return true;

        return EventData.RegisteredAttendees >= EventData.MaxAttendees;
    }

    private string GetRegisterButtonText()
    {
        return IsEventFull() ? "Event Full" : "Register";
    }
}

<style>
    .event-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: #fff;
        margin-bottom: 20px;
    }

    .event-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .card-header {
        width: 100%;
        height: 200px;
        background-color: #f5f5f5;
        overflow: hidden;
    }

    .event-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .event-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-weight: bold;
    }

    .card-body {
        padding: 20px;
    }

    .event-title {
        margin: 0 0 15px 0;
        color: #333;
        font-size: 1.5rem;
    }

    .event-info {
        margin: 15px 0;
    }

    .event-detail {
        margin: 10px 0;
        color: #666;
        line-height: 1.6;
    }

    .card-footer {
        display: flex;
        gap: 10px;
        padding-top: 15px;
        border-top: 1px solid #eee;
        margin-top: 15px;
    }

    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        text-decoration: none;
        cursor: pointer;
        font-size: 0.95rem;
        transition: background-color 0.3s ease;
        display: inline-block;
        text-align: center;
        flex: 1;
    }

    .btn-primary {
        background-color: #667eea;
        color: white;
    }

    .btn-primary:hover {
        background-color: #5568d3;
    }

    .btn-success {
        background-color: #48bb78;
        color: white;
    }

    .btn-success:hover {
        background-color: #38a169;
    }

    .error-card {
        border: 1px solid #fc8181;
        background-color: #fff5f5;
    }

    .error-message {
        color: #c53030;
        text-align: center;
        padding: 20px;
        margin: 0;
    }
</style>
